@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix oeo: <https://openenergyplatform.org/ontology/oeo/> .
@prefix motel: <https://empa.ch/motel/> .

<https://empa.ch/motel/carriers/> a owl:Ontology ;
    rdfs:label "MOTEL Project Energy Carrier Ontology Module"@en ;
    rdfs:comment "A detailed semantic schema representing energy and material carrier classes for the MOTEL project, designed without any individual instances or region-specific classifications."@en ;
    owl:versionInfo "1.3.0" .

### -----------------------------------------------------------------
### Top-Level Classes & Carrier Categories
### -----------------------------------------------------------------

motel:EnergyCarrier a owl:Class ;
    rdfs:label "Energy Carrier"@en ;
    rdfs:comment "A substance, fluid, or physical phenomenon that can be used to store, transport, or yield energy."@en .

# Sub-classes reflecting the Sheet Categories
motel:BioenergyCarrier a owl:Class ;
    rdfs:subClassOf motel:EnergyCarrier ;
    rdfs:label "Bioenergy Carrier"@en .

motel:ElectricityCarrier a owl:Class ;
    rdfs:subClassOf motel:EnergyCarrier ;
    rdfs:label "Electricity Carrier"@en .

motel:ChemicalFuelCarrier a owl:Class ;
    rdfs:subClassOf motel:EnergyCarrier ;
    rdfs:label "Chemical Fuel Carrier"@en .

motel:WasteCarrier a owl:Class ;
    rdfs:subClassOf motel:EnergyCarrier ;
    rdfs:label "Waste Carrier"@en .

motel:ThermalCarrier a owl:Class ;
    rdfs:subClassOf motel:EnergyCarrier ;
    rdfs:label "Thermal Carrier"@en .

motel:HydroCarrier a owl:Class ;
    rdfs:subClassOf motel:EnergyCarrier ;
    rdfs:label "Hydro/Water Kinetic Carrier"@en .

motel:MaterialCarrier a owl:Class ;
    rdfs:subClassOf motel:EnergyCarrier ;
    rdfs:label "Material Carrier (Gasses, Solids & Others)"@en .

### -----------------------------------------------------------------
### Properties (Schema-level definitions)
### -----------------------------------------------------------------

motel:baseCarrier a owl:DatatypeProperty ;
    rdfs:label "base carrier"@en ;
    rdfs:comment "The reference or core chemical formula/phenomenon (e.g., CH4, H2, El)."@en ;
    rdfs:domain motel:EnergyCarrier ;
    rdfs:range xsd:string .

motel:minTemperature a owl:DatatypeProperty ;
    rdfs:label "minimum temperature range [°C]"@en ;
    rdfs:domain motel:ThermalCarrier ;
    rdfs:range xsd:decimal .

motel:maxTemperature a owl:DatatypeProperty ;
    rdfs:label "maximum temperature range [°C]"@en ;
    rdfs:domain motel:ThermalCarrier ;
    rdfs:range xsd:decimal .

### -----------------------------------------------------------------
### Carrier Taxonomic Subclasses (Pure Classes, No Individuals)
### -----------------------------------------------------------------

### 1. Bioenergy Classes
motel:Biomass a owl:Class ;
    rdfs:subClassOf motel:BioenergyCarrier ;
    rdfs:label "Biomass"@en ;
    rdfs:comment "Woody and dry biomass (generic)."@en .

motel:BioWet a owl:Class ;
    rdfs:subClassOf motel:BioenergyCarrier ;
    rdfs:label "BioWet"@en ;
    rdfs:comment "Wet biomass (e.g., sewage sludge, food waste)."@en .

motel:Wood a owl:Class ;
    rdfs:subClassOf motel:BioenergyCarrier ;
    rdfs:label "Wood"@en ;
    rdfs:comment "Energy wood (generic)."@en .

### 2. Electricity Classes
motel:El3 a owl:Class ;
    rdfs:subClassOf motel:ElectricityCarrier ;
    rdfs:label "El3"@en ;
    rdfs:comment "Grid-level electricity, high-voltage transmission levels 1-3 (380-220 kV)."@en .

motel:El7 a owl:Class ;
    rdfs:subClassOf motel:ElectricityCarrier ;
    rdfs:label "El7"@en ;
    rdfs:comment "Grid-level electricity, medium/low-voltage distribution levels 5-7 (1-50 kV)."@en .

motel:ElBdg a owl:Class ;
    rdfs:subClassOf motel:ElectricityCarrier ;
    rdfs:label "ElBdg"@en ;
    rdfs:comment "Behind-the-meter electricity in buildings."@en .

motel:ElRest a owl:Class ;
    rdfs:subClassOf motel:ElectricityCarrier ;
    rdfs:label "ElRest"@en ;
    rdfs:comment "Behind-the-meter electricity at non-residential sites."@en .

motel:ElPVAlpin a owl:Class ;
    rdfs:subClassOf motel:ElectricityCarrier ;
    rdfs:label "ElPVAlpin"@en ;
    rdfs:comment "Electricity from alpine PV installations."@en .

motel:ElWind a owl:Class ;
    rdfs:subClassOf motel:ElectricityCarrier ;
    rdfs:label "ElWind"@en ;
    rdfs:comment "Electricity from wind turbines."@en .

### 3. Chemical Fuel Classes
motel:CH4 a owl:Class ;
    rdfs:subClassOf motel:ChemicalFuelCarrier ;
    rdfs:label "CH4"@en ;
    rdfs:comment "Methane (generic)."@en .

motel:CH4Biogenic a owl:Class ;
    rdfs:subClassOf motel:CH4 ;
    rdfs:label "CH4Biogenic"@en ;
    rdfs:comment "Biogenic methane / Biogas."@en .

motel:CH4Synthetic a owl:Class ;
    rdfs:subClassOf motel:CH4 ;
    rdfs:label "CH4Synthetic"@en ;
    rdfs:comment "Synthetic methane / Power-to-Gas methane."@en .

motel:NaturalGas a owl:Class ;
    rdfs:subClassOf motel:CH4 ;
    rdfs:label "NaturalGas"@en ;
    rdfs:comment "Fossil natural gas."@en .

motel:H2 a owl:Class ;
    rdfs:subClassOf motel:ChemicalFuelCarrier ;
    rdfs:label "H2"@en ;
    rdfs:comment "Hydrogen (generic)."@en .

motel:H2Blue a owl:Class ;
    rdfs:subClassOf motel:H2 ;
    rdfs:label "H2Blue"@en ;
    rdfs:comment "Blue hydrogen produced from fossil fuels with Carbon Capture and Storage (CCS)."@en .

motel:H2Green a owl:Class ;
    rdfs:subClassOf motel:H2 ;
    rdfs:label "H2Green"@en ;
    rdfs:comment "Green hydrogen produced from renewable energy sources."@en .

motel:H2Process a owl:Class ;
    rdfs:subClassOf motel:H2 ;
    rdfs:label "H2Process"@en ;
    rdfs:comment "Process hydrogen, typically mixed with CO in syngas streams."@en .

motel:NH3 a owl:Class ;
    rdfs:subClassOf motel:ChemicalFuelCarrier ;
    rdfs:label "NH3"@en ;
    rdfs:comment "Ammonia."@en .

motel:MeOH a owl:Class ;
    rdfs:subClassOf motel:ChemicalFuelCarrier ;
    rdfs:label "MeOH"@en ;
    rdfs:comment "Methanol."@en .

motel:C8 a owl:Class ;
    rdfs:subClassOf motel:ChemicalFuelCarrier ;
    rdfs:label "C8"@en ;
    rdfs:comment "C8 hydrocarbons (representing gasoline)."@en .

motel:C12 a owl:Class ;
    rdfs:subClassOf motel:ChemicalFuelCarrier ;
    rdfs:label "C12"@en ;
    rdfs:comment "C12 hydrocarbons (representing aviation fuel / kerosene)."@en .

motel:C12Syn a owl:Class ;
    rdfs:subClassOf motel:C12 ;
    rdfs:label "C12Syn"@en ;
    rdfs:comment "Synthesised C12 hydrocarbons (synthetic diesel)."@en .

motel:U235 a owl:Class ;
    rdfs:subClassOf motel:ChemicalFuelCarrier ;
    rdfs:label "U235"@en ;
    rdfs:comment "Nuclear fuel (uranium-235)."@en .

### 4. Waste Classes
motel:Msw a owl:Class ;
    rdfs:subClassOf motel:WasteCarrier ;
    rdfs:label "Msw"@en ;
    rdfs:comment "Municipal solid waste."@en .

### 5. Thermal Classes (Heating & Cooling Categories)
motel:ThAmb a owl:Class ;
    rdfs:subClassOf motel:ThermalCarrier ;
    rdfs:label "ThAmb"@en ;
    rdfs:comment "Ambient heat."@en .

motel:ThGround a owl:Class ;
    rdfs:subClassOf motel:ThermalCarrier ;
    rdfs:label "ThGround"@en ;
    rdfs:comment "Geothermal heat."@en .

motel:ThLt a owl:Class ;
    rdfs:subClassOf motel:ThermalCarrier ;
    rdfs:label "ThLt"@en ;
    rdfs:comment "Low-temperature heat."@en .

motel:ThHt a owl:Class ;
    rdfs:subClassOf motel:ThermalCarrier ;
    rdfs:label "ThHt"@en ;
    rdfs:comment "High-temperature heat."@en .

motel:ThDH a owl:Class ;
    rdfs:subClassOf motel:ThermalCarrier ;
    rdfs:label "ThDH"@en ;
    rdfs:comment "District heating."@en .

### 6. Hydro Classes
motel:HydroRun a owl:Class ;
    rdfs:subClassOf motel:HydroCarrier ;
    rdfs:label "HydroRun"@en ;
    rdfs:comment "Run of river hydro."@en .

motel:HydroS a owl:Class ;
    rdfs:subClassOf motel:HydroCarrier ;
    rdfs:label "HydroS"@en ;
    rdfs:comment "Hydro storage (reservoir)."@en .

### 7. Material Classes
motel:CO2 a owl:Class ;
    rdfs:subClassOf motel:MaterialCarrier ;
    rdfs:label "CO2"@en ;
    rdfs:comment "Carbon dioxide (generic)."@en .

motel:CO2Sys a owl:Class ;
    rdfs:subClassOf motel:CO2 ;
    rdfs:label "CO2Sys"@en ;
    rdfs:comment "CO2 as a resource within the energy system."@en .

motel:CO2Waste a owl:Class ;
    rdfs:subClassOf motel:CO2 ;
    rdfs:label "CO2Waste"@en ;
    rdfs:comment "CO2 from waste incineration exhaust."@en .

motel:CO2Wood a owl:Class ;
    rdfs:subClassOf motel:CO2 ;
    rdfs:label "CO2Wood"@en ;
    rdfs:comment "CO2 from wood-fired power plant exhaust."@en .

motel:CO a owl:Class ;
    rdfs:subClassOf motel:MaterialCarrier ;
    rdfs:label "CO"@en ;
    rdfs:comment "Carbon monoxide."@en .

motel:O2 a owl:Class ;
    rdfs:subClassOf motel:MaterialCarrier ;
    rdfs:label "O2"@en ;
    rdfs:comment "Oxygen."@en .

motel:H2O a owl:Class ;
    rdfs:subClassOf motel:MaterialCarrier ;
    rdfs:label "H2O"@en ;
    rdfs:comment "Water."@en .