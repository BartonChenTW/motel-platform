@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix motel: <https://empa.ch/motel/> .

<https://empa.ch/motel/> a owl:Ontology ;
    rdfs:label "MOTEL Project Ontology (Hub)"@en ;
    rdfs:comment "Hub ontology importing modular MOTEL ontologies for technology, process, and carriers."@en ;
    owl:versionInfo "2.0.0" ;
    owl:imports <https://empa.ch/motel/technology/> ,
                <https://empa.ch/motel/process/> ,
                <https://empa.ch/motel/carriers/> .

# This file is intentionally lightweight and acts as the ontology entry point.
# Core content is maintained in:
# - motel_technology.ttl
# - motel_process.ttl
# - motel_carrier.ttl
