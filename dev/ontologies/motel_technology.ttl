@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix motel: <https://empa.ch/motel/> .

<https://empa.ch/motel/technology/> a owl:Ontology ;
    rdfs:label "MOTEL Technology Ontology Module"@en ;
    rdfs:comment "Technology-focused module containing the technology hierarchy and technology-specific attributes."@en ;
    owl:versionInfo "1.0.0" .

### -----------------------------------------------------------------
### Top-Level Structural Classes (Technology side)
### -----------------------------------------------------------------

motel:MOTELEntity a owl:Class ;
    rdfs:label "MOTEL Entity"@en .

motel:Technology a owl:Class ;
    rdfs:subClassOf motel:MOTELEntity ;
    rdfs:label "Technology"@en ;
    rdfs:comment "The physical asset, system, or plant infrastructure."@en .

### -----------------------------------------------------------------
### Detailed Technology Hierarchy (The Assets / Infrastructure)
### -----------------------------------------------------------------

# 1. Conversion Technologies
motel:ConversionTechnology a owl:Class ;
    rdfs:subClassOf motel:Technology ;
    rdfs:label "Conversion Technology"@en .

# 1.1 Conversion Sub-branches
motel:ElectricityGenerationTechnology a owl:Class ;
    rdfs:subClassOf motel:ConversionTechnology ;
    rdfs:label "Electricity Generation Technology"@en .

motel:ThermalGenerationTechnology a owl:Class ;
    rdfs:subClassOf motel:ConversionTechnology ;
    rdfs:label "Thermal Generation Technology"@en .

motel:ChemicalSynthesisTechnology a owl:Class ;
    rdfs:subClassOf motel:ConversionTechnology ;
    rdfs:label "Chemical Synthesis Technology"@en .

motel:CarbonCaptureTechnology a owl:Class ;
    rdfs:subClassOf motel:ConversionTechnology ;
    rdfs:label "Carbon Capture Technology"@en .

motel:TransmissionInfrastructure a owl:Class ;
    rdfs:subClassOf motel:ConversionTechnology ;
    rdfs:label "Transmission Infrastructure"@en .

# 1.2 Fine-grained Unit Operations under Conversion
motel:GasTurbine a owl:Class ;
    rdfs:subClassOf motel:ElectricityGenerationTechnology ;
    rdfs:label "Gas Turbine Unit"@en .

motel:FuelCell a owl:Class ;
    rdfs:subClassOf motel:ElectricityGenerationTechnology ;
    rdfs:label "Fuel Cell Unit"@en .

motel:HydropowerPlant a owl:Class ;
    rdfs:subClassOf motel:ElectricityGenerationTechnology ;
    rdfs:label "Hydropower Plant"@en .

motel:PhotovoltaicSystem a owl:Class ;
    rdfs:subClassOf motel:ElectricityGenerationTechnology ;
    rdfs:label "Photovoltaic System"@en .

motel:WindTurbine a owl:Class ;
    rdfs:subClassOf motel:ElectricityGenerationTechnology ;
    rdfs:label "Wind Turbine"@en .

motel:NuclearReactor a owl:Class ;
    rdfs:subClassOf motel:ElectricityGenerationTechnology ;
    rdfs:label "Nuclear Reactor"@en .

motel:HeatPumpUnit a owl:Class ;
    rdfs:subClassOf motel:ThermalGenerationTechnology ;
    rdfs:label "Heat Pump Unit"@en .

motel:BoilerSystem a owl:Class ;
    rdfs:subClassOf motel:ThermalGenerationTechnology ;
    rdfs:label "Boiler System"@en .

motel:ElectrolyserUnit a owl:Class ;
    rdfs:subClassOf motel:ChemicalSynthesisTechnology ;
    rdfs:label "Electrolyser Unit"@en .

motel:GasifierUnit a owl:Class ;
    rdfs:subClassOf motel:ChemicalSynthesisTechnology ;
    rdfs:label "Gasifier Unit"@en .

motel:FischerTropschUnit a owl:Class ;
    rdfs:subClassOf motel:ChemicalSynthesisTechnology ;
    rdfs:label "Fischer-Tropsch Unit"@en .

motel:MethanationSabatierUnit a owl:Class ;
    rdfs:subClassOf motel:ChemicalSynthesisTechnology ;
    rdfs:label "Methanation Sabatier Unit"@en .

motel:PyrolyserUnit a owl:Class ;
    rdfs:subClassOf motel:ChemicalSynthesisTechnology ;
    rdfs:label "Pyrolyser Unit"@en .

motel:ElectricalGridNode a owl:Class ;
    rdfs:subClassOf motel:TransmissionInfrastructure ;
    rdfs:label "Electrical Grid Node"@en .

motel:DistrictHeatingNetworkNode a owl:Class ;
    rdfs:subClassOf motel:TransmissionInfrastructure ;
    rdfs:label "District Heating Network Node"@en .

# 2. Storage Technologies
motel:StorageTechnology a owl:Class ;
    rdfs:subClassOf motel:Technology ;
    rdfs:label "Storage Technology"@en .

# 2.1 Storage Sub-branches
motel:ElectrochemicalStorage a owl:Class ;
    rdfs:subClassOf motel:StorageTechnology ;
    rdfs:label "Electrochemical Storage"@en .

motel:MechanicalStorage a owl:Class ;
    rdfs:subClassOf motel:StorageTechnology ;
    rdfs:label "Mechanical Storage"@en .

motel:ThermalStorage a owl:Class ;
    rdfs:subClassOf motel:StorageTechnology ;
    rdfs:label "Thermal Storage"@en .

# 2.2 Fine-grained Unit Operations under Storage
motel:BatteryUnit a owl:Class ;
    rdfs:subClassOf motel:ElectrochemicalStorage ;
    rdfs:label "Battery Storage Unit"@en .

motel:ReservoirUnit a owl:Class ;
    rdfs:subClassOf motel:MechanicalStorage ;
    rdfs:label "Water Reservoir Storage Unit"@en .

motel:ThermalStorageTank a owl:Class ;
    rdfs:subClassOf motel:ThermalStorage ;
    rdfs:label "Thermal/Water Storage Tank"@en .

### -----------------------------------------------------------------
### Technology-focused Properties
### -----------------------------------------------------------------

motel:unitOperationName a owl:DatatypeProperty ;
    rdfs:label "unit operation name"@en ;
    rdfs:domain motel:Technology ;
    rdfs:range xsd:string .
